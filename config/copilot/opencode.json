{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "theme": "opencode",
  "instructions": [
    "~/.config/opencode/caveman-default.md",
    ".github/copilot-instructions.md",
    ".github/instructions/*.md",
    ".github/instructions/**/*.md"
  ],
  "lsp": {
    "pasls": {
      "command": ["pasls"],
      "extensions": [".pas", ".pp", ".inc", ".lpr", ".lpk"],
      "env": {
        "PP": "/opt/homebrew/bin/ppca64",
        "FPCTARGETCPU": "aarch64"
      }
    },
    "clangd": {}
  },
  "formatter": {
    "jcf": {
      "command": ["jcf", "-f", "$FILE"],
      "extensions": [".pas", ".pp", ".inc", ".lpr"]
    },
    "clang-format": {}
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"]
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "pdf-reader": {
      "type": "local",
      "command": ["npx", "-y", "@sylphx/pdf-reader-mcp"]
    },
    "homeassistant": {
      "type": "remote",
      "url": "http://192.168.178.201:8123/api/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:HA_TOKEN}"
      }
    },
    "wireshark-mcp": {
      "type": "local",
      "command": ["python3", "-u", "-m", "wireshark_mcp.server"],
      "environment": {
        "WIRESHARK_MCP_TSHARK_PATH": "/opt/homebrew/bin/tshark",
        "WIRESHARK_MCP_CAPINFOS_PATH": "/opt/homebrew/bin/capinfos",
        "WIRESHARK_MCP_MERGECAP_PATH": "/opt/homebrew/bin/mergecap",
        "WIRESHARK_MCP_EDITCAP_PATH": "/opt/homebrew/bin/editcap",
        "WIRESHARK_MCP_DUMPCAP_PATH": "/opt/homebrew/bin/dumpcap",
        "WIRESHARK_MCP_TEXT2PCAP_PATH": "/opt/homebrew/bin/text2pcap",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
